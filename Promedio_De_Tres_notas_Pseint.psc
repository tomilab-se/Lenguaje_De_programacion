Algoritmo Promedio_De_Notas
	Definir nota1,nota2,nota3 Como Real
	Definir promedio Como Real 
	Escribir "ingrese nota num1"
	Leer nota1
	Escribir"ingrese nota num2"
	Leer nota2
	Escribir "ingrese nota num3"
	Leer nota3
	Promedio <-  (nota1+nota2+nota3) /3
	Escribir"El promedio final es:" Promedio
	
	
	
	
FinAlgoritmo
